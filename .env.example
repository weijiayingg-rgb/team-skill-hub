# Server
PORT=3001
DB_PATH=./data/skillhub.db
REGISTRY_PATH=./data/skillhub-registry
UPLOAD_DIR=./data/uploads

# Auth
ALLOWED_TOKENS=dev-token-1,dev-token-2

# Registry Git
REGISTRY_GIT_URL=
REGISTRY_GIT_BRANCH=main

# 对外可访问的 SkillHub 地址（用于生成安装链接）
# 不配置时自动检测局域网 IP，如需固定地址（如域名）可手动设置
# HUB_URL=http://your-domain.com:3001

# Web
VITE_API_URL=/api
